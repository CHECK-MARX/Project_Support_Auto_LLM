<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B0F14" />
    <SolidColorBrush x:Key="AppPanelBackgroundBrush" Color="#151B23" />
    <SolidColorBrush x:Key="AppForegroundBrush" Color="#E6EDF3" />
    <SolidColorBrush x:Key="AppMutedForegroundBrush" Color="#A6B3C2" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="#364250" />
    <SolidColorBrush x:Key="AppControlBackgroundBrush" Color="#0F141B" />
    <SolidColorBrush x:Key="AppReadOnlyBackgroundBrush" Color="#1B222C" />
    <SolidColorBrush x:Key="AppButtonBackgroundBrush" Color="#0B63CE" />
    <SolidColorBrush x:Key="AppButtonHoverBrush" Color="#1479F2" />
    <SolidColorBrush x:Key="AppTabBackgroundBrush" Color="#1B222C" />
    <SolidColorBrush x:Key="AppSelectionBrush" Color="#1F6FEB" />
    <SolidColorBrush x:Key="AppSelectionForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AppGridHeaderBrush" Color="#202A35" />
    <SolidColorBrush x:Key="AppWarningBrush" Color="#FF7B72" />

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="4,3" />
    </Style>

    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="Margin" Value="4,3" />
        <Setter Property="Padding" Value="4,2" />
    </Style>

    <Style TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource AppButtonBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppSelectionForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppButtonBackgroundBrush}" />
        <Setter Property="Margin" Value="4,3" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="Margin" Value="4,3" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="Margin" Value="4,3" />
    </Style>

    <Style TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
    </Style>

    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Background" Value="{DynamicResource AppPanelBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type TabItem}">
        <Setter Property="Background" Value="{DynamicResource AppTabBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="Padding" Value="10,4" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppButtonBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource AppSelectionForegroundBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type DataGrid}">
        <Setter Property="Background" Value="{DynamicResource AppPanelBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="RowBackground" Value="{DynamicResource AppControlBackgroundBrush}" />
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource AppReadOnlyBackgroundBrush}" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
    </Style>

    <Style TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Background" Value="{DynamicResource AppGridHeaderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="Padding" Value="6,4" />
    </Style>

    <Style TargetType="{x:Type DataGridRow}">
        <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
    </Style>

    <Style TargetType="{x:Type DataGridCell}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    </Style>
</ResourceDictionary>

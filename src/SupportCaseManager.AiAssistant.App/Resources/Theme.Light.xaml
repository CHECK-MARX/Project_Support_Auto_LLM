<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F6F8FA" />
    <SolidColorBrush x:Key="AppPanelBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AppForegroundBrush" Color="#24292F" />
    <SolidColorBrush x:Key="AppMutedForegroundBrush" Color="#57606A" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="#D0D7DE" />
    <SolidColorBrush x:Key="AppControlBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AppReadOnlyBackgroundBrush" Color="#F6F8FA" />
    <SolidColorBrush x:Key="AppButtonBackgroundBrush" Color="#F6F8FA" />
    <SolidColorBrush x:Key="AppSelectionBrush" Color="#DDF4FF" />
    <SolidColorBrush x:Key="AppWarningBrush" Color="#CF222E" />

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="4,3" />
    </Style>

    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="Margin" Value="4,3" />
        <Setter Property="Padding" Value="4,2" />
    </Style>

    <Style TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource AppButtonBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="Margin" Value="4,3" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="Margin" Value="4,3" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="Margin" Value="4,3" />
    </Style>

    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Background" Value="{DynamicResource AppPanelBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type TabItem}">
        <Setter Property="Background" Value="{DynamicResource AppButtonBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <Style TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type DataGrid}">
        <Setter Property="Background" Value="{DynamicResource AppPanelBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="RowBackground" Value="{DynamicResource AppControlBackgroundBrush}" />
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource AppReadOnlyBackgroundBrush}" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
    </Style>
</ResourceDictionary>
